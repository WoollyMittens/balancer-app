<?xml version='1.0' encoding='utf-8'?>
<widget id="com.woollmittens.counterbalancer" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <feature name="Whitelist">
        <param name="android-package" value="org.apache.cordova.whitelist.WhitelistPlugin" />
        <param name="onload" value="true" />
    </feature>
    <name>Counter Balancer</name>
    <description>
        A work in progress concept app for counting calories and balancing exercise.
    </description>
    <author email="maurice@sydneytrainwalks.com" href="http://www.sydneytrainwalks.com/">
        Maurice van Creij
    </author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <allow-intent href="market:*" />
    <preference name="loglevel" value="DEBUG" />
</widget>
